{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.ai/schemas/scheduler/common.schema.json",
  "type": "object",
  "required": ["schema_version", "event_id", "occurred_at", "plugin_version", "run_id", "session_id", "session_key", "agent_id"],
  "properties": {
    "schema_version": {"const": "scheduler.v1"},
    "event_id": {"type": "string", "minLength": 1},
    "occurred_at": {"type": "string", "format": "date-time"},
    "plugin_version": {"type": "string", "minLength": 1},
    "run_id": {"type": ["string", "null"]},
    "session_id": {"type": ["string", "null"]},
    "session_key": {"type": ["string", "null"]},
    "agent_id": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
