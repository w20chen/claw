{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.ai/schemas/scheduler/tool-profile.schema.json",
  "type": "object",
  "required": ["profile_version", "profiles"],
  "properties": {
    "profile_version": {"type": "string"},
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_name", "resource_class", "duration_p50_ms", "duration_p90_ms"],
        "properties": {
          "tool_name": {"type": "string"},
          "operation": {"type": ["string", "null"]},
          "resource_class": {"type": "string"},
          "duration_p50_ms": {"type": "integer", "minimum": 0},
          "duration_p90_ms": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
