# Copy this file to .env at the repository root.
# The sidecar loads .env automatically; no repeated export commands are needed.

AGENT_SCHEDULER_DB_PATH=data/openclaw-trace.sqlite3
AGENT_SCHEDULER_TRACE_PATH=data/trace.jsonl
AGENT_SCHEDULER_RESOURCE_POLL_INTERVAL_MS=50
AGENT_SCHEDULER_RESOURCE_TIMELINE_MAX_POINTS=2000

# The sidecar LLM proxy forwards OpenClaw's Authorization header by default.
# Do not duplicate your provider API key here if OpenClaw already stores it.
# DeepSeek is the built-in default upstream. Set this only for another
# OpenAI-compatible upstream such as vLLM or a custom gateway.
# AGENT_SCHEDULER_LLM_UPSTREAM_BASE_URL=https://api.deepseek.com

# Optional override only if OpenClaw does not send Authorization to the proxy.
# AGENT_SCHEDULER_LLM_UPSTREAM_API_KEY=sk-...

# Optional sidecar auth. Leave unset for local-only development.
# AGENT_SCHEDULER_TOKEN=...
