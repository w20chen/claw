{
  plugins: {
    entries: {
      "hardware-scheduler": {
        enabled: true,
        config: {
          endpoint: "http://127.0.0.1:8765",
          mode: "observe",
          decisionTimeoutMs: 800,
          reportTimeoutMs: 800,
          failOpen: true,
          sendRawParams: false,
          recordRawTrace: true,
          authTokenEnv: "OPENCLAW_SCHEDULER_TOKEN",
          logLevel: "info",

          // hook-only: observe/report without changing exec params.
          // marker: inject CLAW_* env markers into built-in exec.
          // managed-wrapper: rewrite exec command to launcherPath; requires
          // securityBoundaryAccepted=true and a deployed claw-launch binary.
          executionBackend: "hook-only",
          launcherPath: "/opt/claw/bin/claw-launch",
          collectorSocket: "/run/claw/collector.sock",
          instrumentHosts: ["gateway"],
          instrumentTools: ["exec"],
          enableCgroup: true,
          enableAffinity: true,
          enableNuma: true,
          profilingMode: "off",
          securityBoundaryAccepted: false
        }
      }
    }
  }
}
